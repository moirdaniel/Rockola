# Database
# Por defecto se usa backend/data/rockola.db (ruta absoluta del proyecto).
# Si quieres otra ruta, descomenta y ajusta (absoluta recomendada si hay "unable to open database file"):
# DATABASE_URL=sqlite:./data/rockola.db
# DATABASE_URL=sqlite:/ruta/absoluta/backend/data/rockola.db

# Server
# Si el puerto 3000 está ocupado, usa 3001 y en frontend/vite.config.ts pon target: http://localhost:3001
PORT=3000
RUST_LOG=info

# Media: directorio raíz para audio/video descargados (yt-dlp). Estructura: rockola-media/audio/youtube/, etc.
MEDIA_ROOT=./rockola-media

# yt-dlp: comando o ruta completa. REQUERIDO para búsqueda en YouTube.
# Instalar: Arch: sudo pacman -S yt-dlp ffmpeg  |  Otros: pip install yt-dlp  o  https://github.com/yt-dlp/yt-dlp
# Si no está en PATH, usa ruta absoluta, ej: YT_DLP_PATH=/usr/bin/yt-dlp
YT_DLP_PATH=yt-dlp

# Credits: cost per song in credits
COST_PER_SONG=100
